# Local secrets for development.
#
# Copy this file to `.env` (git-ignored — never commit it) and fill in the values.
# The application reads `.env` from the app root at startup (see EmbeddingConfiguration).
#
# Alternative ways to supply the key:
#   - export OPENAI_API_KEY in your shell before starting the app
#   - set openai.api-key in src/main/resources/config/application-dev.yml

# OpenAI API key used to generate vector embeddings for AI search.
OPENAI_API_KEY=
